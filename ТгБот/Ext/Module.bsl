 //Получить список задач
 Функция ПолучитьСписокЗадачТг() Экспорт
	   Запрос = Новый Запрос;
	   Запрос.Текст=
	    "ВЫБРАТЬ
	    |	Задачи.Наименование КАК Текст,
	    |	Задачи.ДатаИсполнения КАК Дата,
	    |	Задачи.Описание КАК Описание
	    |ИЗ
	    |	Справочник.Задачи КАК Задачи
	    |ГДЕ
	    |	Задачи.Статус = Ложь
	    |УПОРЯДОЧИТЬ ПО
	    |   Задачи.ДатаИсполнения";
	   Выборка = Запрос.Выполнить().Выбрать();
	   
	   Если Выборка.Количество() = 0 Тогда
        		Возврат "У вас пока нет активных задач. Отдыхайте! ";
   	   КонецЕсли;
	   
	    Текст = " Список ваших задач:" + Символы.ПС + "---------------------------" + Символы.ПС;
	    Счетчик = 1;
	    Пока Выборка.Следующий() Цикл
		    Текст = Текст + Счетчик + ". " + Формат(Выборка.Дата, "ДФ='dd.MM HH:mm'") + " — " + Выборка.Текст + Символы.ПС + Выборка.Описание + Символы.ПС + Символы.ПС;
		    Счетчик = Счетчик + 1;
	    КонецЦикла;
   	
	   Возврат Текст;
 КонецФункции
 //Добавить задачу
 Функция ДобавитьЗадачуТг(ВходнаяСтрока) Экспорт
	 
	 ПозЦифры = 0;
    Для НомерСимвола = 1 По СтрДлина(ВходнаяСтрока) Цикл
        КодСимвола = КодСимвола(Сред(ВходнаяСтрока, НомерСимвола, 1));
        Если КодСимвола >= 48 И КодСимвола <= 57 Тогда
            ПозЦифры = НомерСимвола;
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    Если ПозЦифры = 0 Тогда
        Текст = "❌ Ошибка! Не указана дата (нужны цифры).";
        Возврат Текст;
    КонецЕсли;
    
    // 2. Делим строку на "До" и "После"
    Название = СокрЛП(Лев(ВходнаяСтрока, ПозЦифры - 1));
    Параметры = СокрЛП(Сред(ВходнаяСтрока, ПозЦифры));
    
    МассивПарам = СтрРазделить(Параметры, " ");
    Если МассивПарам.Количество() < 4 Тогда
        Текст = "❌ Ошибка! Проверьте дату, время, тип напоминания и периодичность.";
        Возврат Текст;
    КонецЕсли;
    
    ДатаСтр = МассивПарам[0];
    ВремяСтр = МассивПарам[1];
    ТипСтр = МассивПарам[2];
    ПериодСтр = МассивПарам[3];
    
    // 4. Пытаемся записать в базу
    Попытка
        НоваяЗадача = Справочники.Задачи.СоздатьЭлемент();
        НоваяЗадача.Наименование = Название;
        
                Д = ДатаСтр; В = ВремяСтр;
        Стр1С = Прав(Д,4) + Сред(Д,4,2) + Лев(Д,2) + СтрЗаменить(В,":","") + "00";
        НоваяЗадача.ДатаИсполнения = Дата(Стр1С);
	   
        // Ищем значение перечисления по имени
        НоваяЗадача.Напоминание = Перечисления.ТипыНапоминаний[ТипСтр];
        НоваяЗадача.Периодичность = Перечисления.ТипыПериодичностиЗадач[ПериодСтр];
        НоваяЗадача.Записать();
        Текст = "✅ Задача '" + Название + "' добавлена!";
	   Возврат Текст;
    Исключение
        Текст = "❌ Ошибка формата! Проверьте дату (ДД.ММ.ГГГГ) и Тип.";
    КонецПопытки;
	 
КонецФункции
//Выполнить задачу
Функция ВыполнитьЗадачуТг(ВходнаяСтрока) Экспорт
	ЗадачаСсылка = Справочники.Задачи.НайтиПоКоду(ВходнаяСтрока);
	Если НЕ ЗадачаСсылка.Пустая() Тогда
	Объект = ЗадачаСсылка.ПолучитьОбъект();
		Если Объект.Периодичность = Перечисления.ТипыПериодичностиЗадач.Нет Тогда
		Объект.Статус = Истина;
		Объект.НапоминаниеОтправлено = Истина;
		Объект.УведомлениеОСобытииОтправлено = Истина;
		Объект.Записать();
		 Текст = "✅ Задача '" + Объект.Наименование + "' выполнена!";
	 	ИначеЕсли Объект.Периодичность = Перечисления.ТипыПериодичностиЗадач.Ежедневно Тогда
		 Объект.ДатаИсполнения = Объект.ДатаИсполнения + 86400;
		 Объект.НапоминаниеОтправлено = Ложь;
		Объект.УведомлениеОСобытииОтправлено = Ложь;
		Текст = "✅ Задача '" + Объект.Наименование + "' выполнена!";
		 ИначеЕсли Объект.Периодичность = Перечисления.ТипыПериодичностиЗадач.Ежедневно Тогда
		 Объект.ДатаИсполнения = Объект.ДатаИсполнения + (7*86400);
		 Объект.НапоминаниеОтправлено = Ложь;
		Объект.УведомлениеОСобытииОтправлено = Ложь;
		Текст = "✅ Задача '" + Объект.Наименование + "' выполнена!";
		ИначеЕсли Объект.Периодичность = Перечисления.ТипыПериодичностиЗадач.Ежедневно Тогда
		 Объект.ДатаИсполнения = ДобавитьМесяц(Объект.ДатаИсполнения, 1);
		 Объект.НапоминаниеОтправлено = Ложь;
		Объект.УведомлениеОСобытииОтправлено = Ложь;
		Текст = "✅ Задача '" + Объект.Наименование + "' выполнена!";
		Иначе
      	Текст = "❌ Ошибка: задача с кодом " + ВходнаяСтрока + " не найдена.";
	 	КонецЕсли;
	 КонецЕсли;
	 Возврат Текст;
 КонецФункции  
//Отложить задачу 
Функция ОтложитьЗадачуТг(ВходнаяСтрока) Экспорт
	  ЗадачаСсылка = Справочники.Задачи.НайтиПоКоду(ВходнаяСтрока);
	Если НЕ ЗадачаСсылка.Пустая() Тогда
		Объект = ЗадачаСсылка.ПолучитьОбъект();
		Объект.ДатаИсполнения = Объект.ДатаИсполнения + 86400;
		Объект.НапоминаниеОтправлено = Ложь;
        Объект.УведомлениеОСобытииОтправлено = Ложь;
        Объект.Записать();
        НовоеВремя = Формат(Объект.ДатаИсполнения, "ДФ='dd.MM.yyyy HH:mm'");
        Текст = "↩️ Задача '" + Объект.Наименование + "' отложена на завтра. " + Символы.ПС + "Новое время: " + НовоеВремя;
    Иначе
        Текст = "❌ Ошибка: задача не найдена.";
   КонецЕсли; 
   Возврат Текст;
КонецФункции
