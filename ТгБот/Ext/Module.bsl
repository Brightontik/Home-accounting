//Функция по определению имя тэга
Функция ОпределитьИмяТегаПоТексту(ТекстСТегом) Экспорт
    ПозТега = Найти(ТекстСТегом, "#");
    СтрокаПослеРешетки = СокрЛП(Сред(ТекстСТегом, ПозТега + 1));
    ПозПробела = Найти(СтрокаПослеРешетки, " ");
    ИмяТега = ВРег(?(ПозПробела > 0, Лев(СтрокаПослеРешетки, ПозПробела - 1), СтрокаПослеРешетки));
    Возврат ИмяТега;
КонецФункции
//Функция по определению типа тэга
Функция ОпределитьТипИнформацииПоТексту(ИмяТега) Экспорт
    
    Если ИмяТега = "УЧЕБА" Тогда
        Возврат Перечисления.ТипыИнформацииБазыЗнаний.Учеба;
    ИначеЕсли ИмяТега = "ИДЕЯ" Тогда
        Возврат Перечисления.ТипыИнформацииБазыЗнаний.Идея;
    ИначеЕсли ИмяТега = "ССЫЛКА"  Тогда
        Возврат Перечисления.ТипыИнформацииБазыЗнаний.Ссылка;
    Иначе
        Возврат Перечисления.ТипыИнформацииБазыЗнаний.Заметка;
    КонецЕсли;
    
КонецФункции
