#Область ОбработчикСообщенийТг
//Для рег. задачи
Процедура ОбработатьСообщениеРеалтайм() Экспорт
	ОбработатьНовыеСообщения();
КонецПроцедуры
//Получение сообщение
Функция ПолучитьОбновленияБота()  Экспорт
	
	ПоследнийID = Константы.ПоследнийНомерСообщенияТГ.Получить();
	
	Токен = "8606429339:AAGFtWL6gjBG68coDY29E_HTltFzz-62lWQ";
	ПараметрOffset = ?(ПоследнийID=0, "", "&offset=" + Формат(ПоследнийID, "ЧГ=0"));
	
	
	Ресурс = "bot" + Токен + "/getUpdates?timeout=50" + ПараметрOffset;
	
	Попытка
		Соединение = Новый HTTPСоединение("api.telegram.org",,,,,60,Новый ЗащищенноеСоединениеOpenSSL());
		Запрос = Новый HTTPЗапрос(Ресурс);
		Ответ = Соединение.Получить(Запрос);
		
		Если Ответ.КодСостояния = 200 Тогда
			Возврат Ответ.ПолучитьТелоКакСтроку();
		Иначе
			ЗаписьЖурналаРегистрации("Ошибка_ТГ",,,,"Код состояния: " + Ответ.КодСостояния);
			Возврат "";
		КонецЕсли;
	Исключение
		ЗаписьЖурналаРегистрации("Ошибка_ТГ",,,,ОписаниеОшибки());
		Возврат "";
		КонецПопытки;
	     
	КонецФункции
//Чтение сообщения	
Процедура ОбработатьНовыеСообщения()  Экспорт
	ПроверитьНапоминанияБазыЗнаний();	
	ТекстJSON = ПолучитьОбновленияБота();
	Если ПустаяСтрока(ТекстJSON) Тогда Возврат; КонецЕсли;
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(ТекстJSON);
	Данные = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();
	
	Если Данные.ok И Данные.result.Количество()> 0 Тогда
		Для Каждого Обновление из Данные.result Цикл
			
			Сообщение = Обновление.message;
			АвторID = Сообщение.from.id;
			
			Имя = Сообщение.from.first_name;
			ЛогинТг = ""; 
			Если Сообщение.from.Свойство("username") Тогда
				ЛогинТг = " (@" + Сообщение.from.username + ")";
				КонецЕсли;
                
Если Сообщение.Свойство("photo") Тогда
    ТекстПодписи = "";
    Если Сообщение.Свойство("caption") Тогда
        ТекстПодписи = Сообщение.caption;
    КонецЕсли;
    Если Найти(ТекстПодписи, "#") > 0 Тогда
        // Достаем file_id самого большого фото
        МассивФото = Сообщение.photo;
        ФайлID = МассивФото[МассивФото.Количество() - 1].file_id;
        // Вызываем сохранение
        ОбработатьФотоИзТГ(ФайлID, ТекстПодписи, АвторID);
    Иначе
         ОтправитьСообщение(АвторID, " Вижу фото, но без тега сохранять не буду.");
    КонецЕсли;
		ИначеЕсли Сообщение.Свойство("text") Тогда
    		ТекстКоманды = Сообщение.text; 
		ПользовательСсылка = Справочники.Пользователи.НайтиПоРеквизиту("ТелеграмID", АвторID);
		Если НЕ ПользовательСсылка.Пустая() Тогда
			Если ПользовательСсылка.ВходРазрешен Тогда 
       			 АнализироватьКоманду(ТекстКоманды, АвторID);
       			 ПроверитьКалендарьИЗадачи(АвторID);
    			Иначе
        			ОтправитьСообщение(АвторID, "Ваш доступ временно приостановлен.");
    			КонецЕсли;
			Иначе
			ПолноеИмя = Имя + ЛогинТг;
			Менеджер = РегистрыСведений.ЛогТелеграммБота.СоздатьМенеджерЗаписи();
			Менеджер.ДатаСобытия = ТекущаяДата();
			Менеджер.ТелеграммID = АвторID;
			Менеджер.ИмяПользователя = ПолноеИмя;
			Менеджер.ТипЗапроса = ТекстКоманды;
			Менеджер.ТипСобытия = "Попытка взлома";
			Менеджер.Записать();
			ОтправитьСообщение(АвторID, "Доступ запрещён");
			КонецЕсли;
			Константы.ПоследнийНомерСообщенияТГ.Установить(Обновление.update_id + 1);
		
		КонецЕсли;
		КонецЦикла;
	КонецЕсли;
		
КонецПроцедуры   
//Обработчик фото
Процедура ОбработатьФотоИзТГ(ФайлID, ТекстПодписи, АвторID)
    
    Токен = "8606429339:AAGFtWL6gjBG68coDY29E_HTltFzz-62lWQ";
    Соединение = Новый HTTPСоединение("api.telegram.org", , , , , , Новый ЗащищенноеСоединениеOpenSSL());
    РесурсПуть = "bot" + СокрЛП(Токен) + "/getFile?file_id=" + СокрЛП(ФайлID);
	ЗапросПуть = Новый HTTPЗапрос(РесурсПуть);
	
	Попытка
		ОтветПуть = Соединение.Получить(ЗапросПуть);
		Если ОтветПуть.КодСостояния <> 200 Тогда
			ЗаписьЖурналаРегистрации("ТГ_ОШИБКА", , , , "Ошибка getFile: " + ОтветПуть.КодСостояния);
			Возврат;
		КонецЕсли;
		
		// Читаем путь из JSON
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ОтветПуть.ПолучитьТелоКакСтроку());
		ДанныеРезультата = ПрочитатьJSON(ЧтениеJSON);
		ПустьКФайлу = ДанныеРезультата.result.file_path;
		
	Исключение
		ЗаписьЖурналаРегистрации("ТГ_ОШИБКА", , , , "Сеть: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки;
	
	// ЭТАП 2: Скачиваем сам файл
	// Путь в телеграме выглядит так: /file/bot<token>/<file_path>
	РесурсФайл = "file/bot" + СокрЛП(Токен) + "/" + ПустьКФайлу;
	ЗапросФайл = Новый HTTPЗапрос(РесурсФайл);
	
	Попытка
		ОтветФайл = Соединение.Получить(ЗапросФайл);
		
		Если ОтветФайл.КодСостояния = 200 Тогда
			// Получаем картинку сразу в ДвоичныеДанные
			КартинкаДанные = ОтветФайл.ПолучитьТелоКакДвоичныеДанные();
			
			// ЭТАП 3: Создаем записи в 1С
			ТекПользователь = ОпределитьПользователяПоID(АвторID);
	   ИмяТега = ОпределитьИмяТегаПоТексту(ТекстПодписи);
	   ТипИнфо = ОпределитьТипИнформацииПоТексту(ИмяТега);
	   ТекстБезТега = СокрЛП(СтрЗаменить(ТекстПодписи, "#" + ИмяТега, ""));
        НоваяЗаметка = Справочники.БазаЗнаний.СоздатьЭлемент();
        НоваяЗаметка.Наименование = "Фото: " + ?(ПустаяСтрока(ТекстБезТега), ТекущаяДата(), Лев(ТекстБезТега, 50));
        НоваяЗаметка.Содержание = ТекстБезТега;
        НоваяЗаметка.ДатаДобавления = ТекущаяДата();
	   НоваяЗаметка.ТипИнформации = ТипИнфо;
	   НоваяЗаметка.Тег = ИмяТега;
	   НоваяЗаметка.Пользователь = ТекПользователь;
        НоваяЗаметка.Записать();
	   
			// Сохраняем картинку
			НовыйФайл = Справочники.ПрисоединенныеФайлыБазыЗнаний.СоздатьЭлемент();
			НовыйФайл.Владелец = НоваяЗаметка.Ссылка;
			НовыйФайл.Наименование = "image.jpg";
			НовыйФайл.Файл = Новый ХранилищеЗначения(КартинкаДанные);
			НовыйФайл.Записать();
			
			ОтправитьСообщение(АвторID, " Фото сохранено в твой 'Второй мозг'!");
		КонецЕсли;
		
	Исключение
		ЗаписьЖурналаРегистрации("ТГ_ОШИБКА", , , , "Ошибка загрузки файла: " + ОписаниеОшибки());
	КонецПопытки;    
   
КонецПроцедуры
//Команды			
Процедура АнализироватьКоманду(ТекстКоманды, ЧатID)
	ТекстВРег = ВРег(СокрЛП(ТекстКоманды));
#Область Хэштег
ПозТега = Найти(ТекстКоманды, "#");
Если ПозТега > 0 Тогда
	 ТекПользователь = ОпределитьПользователяПоID(ЧатID);
    ИмяТега = ОпределитьИмяТегаПоТексту(ТекстКоманды);
    ТипИнфо = ОпределитьТипИнформацииПоТексту(ИмяТега);    
    ТекстБезТега = СокрЛП(СтрЗаменить(ТекстКоманды, "#" + ИмяТега, ""));
    НоваяЗаметка = Справочники.БазаЗнаний.СоздатьЭлемент();
    НоваяЗаметка.Наименование = Лев(ТекстБезТега, 100); // Краткий заголовок
    НоваяЗаметка.Содержание  = ТекстБезТега;
    НоваяЗаметка.ТипИнформации = ТипИнфо;
    НоваяЗаметка.Тег           = ИмяТега;
    НоваяЗаметка.Пользователь = ТекПользователь;
    НоваяЗаметка.ДатаДобавления = ТекущаяДата();
    
    Попытка
        НоваяЗаметка.Записать();
        ОтправитьСообщение(ЧатID, " Сохранено в Базу Знаний (" + ТипИнфо + ")");
        Возврат; 
    Исключение
        ОтправитьСообщение(ЧатID, "❌ Ошибка при сохранении заметки!");
    КонецПопытки;    
КонецЕсли;
#КонецОбласти

#Область Команды
	Если ТекстВРег = "/START" Тогда
		Меню = " Привет! Я твой помощник 1С." + Символы.ПС +
		       "Вот что я умею:" + Символы.ПС + Символы.ПС +
		       " /ExchangeRate — Курсы валют от ЦБ" + Символы.ПС +
		       " /Report — Твои расходы (План/Факт)" + Символы.ПС +
			  " /DetailedReport — Твои расходы по категориям" + Символы.ПС +
			  " /Dynamics — Динамика расходов к плану" + Символы.ПС +
			  " /Calendar — Календарь" + Символы.ПС +
		  	  " /Tasks — Задачи и напоминания в календарь" + Символы.ПС +
			  " /Статус — Состояние системы" + Символы.ПС +
		       " /Логи — Попытки чужого доступа" + Символы.ПС + Символы.ПС +
		       "Выбери команду или просто напиши её!";
		ОтправитьСообщение(ЧатID, Меню);
		
	ИначеЕсли ТекстВРег = "/EXCHANGERATE" Тогда 
		ТекстОтвета = ПолучитьТекстКурсаДляТг();
		ОтправитьСообщение(ЧатID, ТекстОтвета);
		
	ИначеЕсли ТекстВРег = "/REPORT" Тогда
		ТекстОтвета = СформироватьОтчетИзРегистраИтоги(ЧатID);
		 ОтправитьСообщение(ЧатID, ТекстОтвета);
		
	ИначеЕсли ТекстВРег = "/DETAILEDREPORT" Тогда
		ТекстОтвета = СформироватьОтчётКатегорийИтоги(ЧатID);
		 ОтправитьСообщение(ЧатID, ТекстОтвета) 
		
	ИначеЕсли ТекстВРег = "/DYNAMICS" Тогда
		ТекстОтвета = СформироватьПрогнозТемпа(ЧатID);
		 ОтправитьСообщение(ЧатID, ТекстОтвета)
		
	ИначеЕсли ТекстВРег = "/CALENDAR" Тогда
		ТекстОтвета = СформироватьКалендарь();
		 ОтправитьСообщение(ЧатID, ТекстОтвета)
		
	ИначеЕсли ТекстВРег = "/TASKS" Тогда
		ТекстОтвета = " Список команд для задач в календаре" + Символы.ПС + Символы.ПС+
		"/ShowTasks - показать существующие задачи" + Символы.ПС +
		"/Add - Добавить в колендарь" +  Символы.ПС +
		"Пример: /Add Покормить кота 18.04.2026 19:00 ЗаЧас Ежедневно" +  Символы.ПС +
		"Типы Напоминаний: За15Минут, ЗаЧас,  ЗаДень" +  Символы.ПС +
		"Типы Периодичности: Нет, Ежедневно, Еженедельно, Ежемесячно";
		 ОтправитьСообщение(ЧатID, ТекстОтвета) 
		
	ИначеЕсли Лев(ТекстВРег, 4) = "/ADD" Тогда
		 ВходнаяСтрока = СокрЛП(Сред(ТекстКоманды, 5));
		ТекстОтвета = ДобавитьЗадачуТг(ВходнаяСтрока);
		 ОтправитьСообщение(ЧатID, ТекстОтвета);	 
		 
	ИначеЕсли Лев(ТекстВРег, 6) = "/DONE_" Тогда
		КодЗадачи = Сред(ТекстКоманды, 7);
		ТекстОтвета = ВыполнитьЗадачуТг(КодЗадачи);
		 ОтправитьСообщение(ЧатID, ТекстОтвета);
		 
	ИначеЕсли Лев(ТекстВРег, 10) = "/POSTPONE_" Тогда
		КодЗадачи = Сред(ТекстКоманды, 11);
		ТекстОтвета = ОтложитьЗадачуТг(КодЗадачи);
		 ОтправитьСообщение(ЧатID, ТекстОтвета);
		 
	ИначеЕсли ТекстВРег = "/SHOWTASKS" Тогда
		ТекстОтвета = ПолучитьСписокЗадачТг();
		 ОтправитьСообщение(ЧатID, ТекстОтвета);	 
		
	ИначеЕсли ТекстВРег = "/DYNAMICS" Тогда
		ТекстОтвета = СформироватьПрогнозТемпа(ЧатID);
		 ОтправитьСообщение(ЧатID, ТекстОтвета);
		 
	Иначе
		ОтправитьСообщение(ЧатID, "Пока не знаю такой команды");
	КонецЕсли;
#КонецОбласти
КонецПроцедуры 
#Область ПроцедурыВспомогательные
//Календарь
Процедура ПроверитьКалендарьИЗадачи(ЧатID) Экспорт
	Запрос = Новый Запрос;
     Запрос.Текст = 
    "ВЫБРАТЬ

    |   Задачи.Ссылка,
    |   Задачи.Наименование КАК Текст,
    |   Задачи.ДатаИсполнения КАК ДатаСобытия,

    |   Задачи.Напоминание КАК Тип,
    |   Задачи.НапоминаниеОтправлено КАК БылоНапоминание,
    |   Задачи.УведомлениеОСобытииОтправлено КАК Уведомление
    |ИЗ

    |   Справочник.Задачи КАК Задачи
    |ГДЕ
    |   НЕ Задачи.Статус";
    
    Выборка = Запрос.Выполнить().Выбрать();
    ТекВремя = ТекущаяДата();
    
    Пока Выборка.Следующий() Цикл       
        Если НЕ Выборка.БылоНапоминание Тогда
            СекундДо = ПолучитьСекундыИзТипаНапоминания(Выборка.Тип);
            ВремяНапоминания = Выборка.ДатаСобытия - СекундДо;
            
            Если ТекВремя >= ВремяНапоминания И ТекВремя < Выборка.ДатаСобытия Тогда
                ТекстУвед = " *СКОРО:* " + Выборка.Текст + " (" + Формат(Выборка.ДатаСобытия, "ДФ=HH:mm") + ")";
                ОтправитьСообщение(ЧатID, ТекстУвед);
                Объект = Выборка.Ссылка.ПолучитьОбъект();
                Объект.НапоминаниеОтправлено = Истина;
                Объект.Записать();
            КонецЕсли;
        КонецЕсли;
        Если НЕ Выборка.Уведомление Тогда
        Если ТекВремя >= Выборка.ДатаСобытия Тогда
            // Шлем финальное уведомление
            ТекстФИН = "⚠️ *ПОРА:* " + Выборка.Текст + "!" + Символы.ПС +
                       "Выполнить: /done_" + Выборка.Ссылка.Код + Символы.ПС +
                       "Отложить: /postpone_" + Выборка.Ссылка.Код;
            
            ОтправитьСообщение(ЧатID, ТекстФИН);
            
            Объект = Выборка.Ссылка.ПолучитьОбъект();
            Объект.УведомлениеОСобытииОтправлено = Истина;
		  Объект.Записать();
	  КонецЕсли;
	  КонецЕсли;
        
    КонецЦикла;
    
КонецПроцедуры
Процедура ПроверитьНапоминанияБазыЗнаний() Экспорт
	
	Запрос = Новый Запрос;
	// Ищем заметки, созданные более 24 часов назад, о которых еще не напоминали
	Запрос.Текст = 
	"ВЫБРАТЬ

	|	База.Ссылка КАК Ссылка,
	|	База.Пользователь КАК Пользователь,
	|	База.ТипИнформации КАК Тип,

	|	База.Содержание КАК Текст
	|ИЗ
	|	Справочник.БазаЗнаний КАК База

	|ГДЕ
	|	НЕ База.НапоминаниеОтправлено
	|	И База.ДатаДобавления <= &ДатаСреза";
	
	// Напоминаем через 1 день (86400 секунд)
	Запрос.УстановитьПараметр("ДатаСреза", ТекущаяДата() - 86400);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
    
    ЧатID = ОпределитьIDПоПользователю(Выборка.Пользователь);
    
    Если ЧатID = 0 Тогда       
	    Продолжить;
    КонецЕсли;

    Заголовок = " *Вспомни это:* " + Выборка.Тип;
    ТекстСообщения = Заголовок + Символы.ПС + "---------------------------" + Символы.ПС + Выборка.Текст;
    
    // Ищем, есть ли у этой заметки прикрепленный файл
    ЗапросФайла = Новый Запрос;
	ЗапросФайла.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.ПрисоединенныеФайлыБазыЗнаний ГДЕ Владелец = &Владелец";
	ЗапросФайла.УстановитьПараметр("Владелец", Выборка.Ссылка);
	РезультатФайла = ЗапросФайла.Выполнить();

	Если НЕ РезультатФайла.Пустой() Тогда
    	ВыборкаФайла = РезультатФайла.Выбрать();
   	 ВыборкаФайла.Следующий();
   	 ФайлСсылка = ВыборкаФайла.Ссылка;
        
        ДвоичныеДанные = ФайлСсылка.Файл.Получить(); 
        ОтправитьФото(ЧатID, ДвоичныеДанные, ТекстСообщения);
    Иначе
        ОтправитьСообщение(ЧатID, ТекстСообщения); 
    КонецЕсли;
    
    // 4. Помечаем, что напомнили
    Объект = Выборка.Ссылка.ПолучитьОбъект();
    Объект.НапоминаниеОтправлено = Истина;
    Объект.Записать();
    
	КонецЦикла;
КонецПроцедуры
#КонецОбласти
#Область ОтправкаСообщений
//Отправка сообщения в чат
Процедура ОтправитьСообщение(ЧатID, Текст) Экспорт
	  Токен = "8606429339:AAGFtWL6gjBG68coDY29E_HTltFzz-62lWQ";
