//Отправка сообщения с фото в чат	 
Процедура ОтправитьФото(ЧатID, ДвоичныеДанныеКартинки, Подпись = "") Экспорт
	Токен = "8606429339:AAGFtWL6gjBG68coDY29E_HTltFzz-62lWQ";
	Boundary = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
		
	НачалоТела = "--" + Boundary + Символы.ПС +
	             "Content-Disposition: form-data; name=""chat_id""" + Символы.ПС + Символы.ПС +
	             Формат(ЧатID, "ЧГ=0") + Символы.ПС +
	             "--" + Boundary + Символы.ПС +
	             "Content-Disposition: form-data; name=""caption""" + Символы.ПС + Символы.ПС +
	             Подпись + Символы.ПС +
	             "--" + Boundary + Символы.ПС +
	             "Content-Disposition: form-data; name=""photo""; filename=""image.jpg""" + Символы.ПС +
	             "Content-Type: image/jpeg" + Символы.ПС + Символы.ПС;
	
	КонецТела = Символы.ПС + "--" + Boundary + "--" + Символы.ПС;
	
	// 2. Склеиваем всё в один кусок двоичных данных
	// Сначала текст в байты
	ДанныеНачала = ПолучитьДвоичныеДанныеИзСтроки(НачалоТела, КодировкаТекста.UTF8, Ложь);
	ДанныеКонца  = ПолучитьДвоичныеДанныеИзСтроки(КонецТела, КодировкаТекста.UTF8, Ложь);
	
	// Собираем массив из кусочков в правильном порядке
	МассивДляСборки = Новый Массив;
	МассивДляСборки.Добавить(ДанныеНачала);
	МассивДляСборки.Добавить(ДвоичныеДанныеКартинки);
	МассивДляСборки.Добавить(ДанныеКонца);
	
	// Теперь склеиваем массив в один монолитный объект
	РезультатДанные = СоединитьДвоичныеДанные(МассивДляСборки);	
	// 3. Отправляем
	Ресурс = "bot" + Токен + "/sendPhoto";
	Соединение = Новый HTTPСоединение("api.telegram.org", , , , , , Новый ЗащищенноеСоединениеOpenSSL());
	
	Запрос = Новый HTTPЗапрос(Ресурс);
	Запрос.Заголовки.Вставить("Content-Type", "multipart/form-data; boundary=" + Boundary);
	
	// В 8.3.27 этот метод — базовый
	Запрос.УстановитьТелоИзДвоичныхДанных(РезультатДанные);
	
	Попытка
		Соединение.Отправить(Запрос);
	Исключение
		ЗаписьЖурналаРегистрации("ТГ_ОШИБКА", , , , ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры	 
