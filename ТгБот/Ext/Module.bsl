 #Область МоментальныеКомандыТг
 //Курс
 Функция  ПолучитьТекстКурсаДляТг()
	
	ВсеКурсы = ВыгрузкаИзЦБКурса.ПолучитьКурсВалют(ТекущаяДата());
	
	Если ВсеКурсы = Неопределено или Всекурсы.Количество() = 0 Тогда
		Возврат "Не удалось сделать выгрузку из ЦБ, попробуйте ещё раз или обратитесь к админу";
	КонецЕсли;
	
	Текст = "*Курс Валют ЦБ на" + Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy") + "*" + Символы.ПС;
	Текст = Текст + "---------------------------" + Символы.ПС;
	
	НужныеВалюты = "USD,EUR,CNY,BYN";
	
	МассивКодов = СтрРазделить(НужныеВалюты, ",");
	
	Для Каждого Код из МассивКодов Цикл
		Курс=ВсеКурсы.Получить(Код);
		Если Курс <> Неопределено Тогда
			 Текст = Текст + " *" + Код + "*: " + Формат(Курс, "ЧДЦ=2; ЧРД=.") + " руб." + Символы.ПС;
		 КонецЕсли;
	 КонецЦикла;
	 
	 Текст = Текст + "---------------------------" + Символы.ПС;
    Текст = Текст + "_Обновлено автоматически_ ";
    
    Возврат Текст;
		
КонецФункции  
//Отчёт категорий
Функция СформироватьОтчётКатегорийИтоги(ЧатID) Экспорт
	
	ТекПользователь = ОпределитьПользователяПоID(ЧатID);
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ

	|	ВЫБОР КОГДА ТЧ.Категория.ЭтоГруппа ТОГДА ТЧ.Категория ИНАЧЕ ТЧ.Категория.Родитель КОНЕЦ КАК Категория,
	|	СУММА(ТЧ.Сумма) КАК План
	|ПОМЕСТИТЬ ВТ_План

	|ИЗ
	|	Документ.ПланБюджетаМесяца.ПланПоКатегориям КАК ТЧ
	|ГДЕ

	|	ТЧ.Ссылка.Проведен И ТЧ.Ссылка.Пользователь = &Пользователь
	|	И НАЧАЛОПЕРИОДА(ТЧ.Ссылка.МесяцПлана, МЕСЯЦ) = &Месяц
	|СГРУППИРОВАТЬ ПО

	|	ВЫБОР КОГДА ТЧ.Категория.ЭтоГруппа ТОГДА ТЧ.Категория ИНАЧЕ ТЧ.Категория.Родитель КОНЕЦ
	|;
	|////////////////////////////////////////////////////////////////////////////////

	|ВЫБРАТЬ
	|	ВЫБОР КОГДА Рег.Категория.ЭтоГруппа ТОГДА Рег.Категория ИНАЧЕ Рег.Категория.Родитель КОНЕЦ КАК Категория,
	|	СУММА(Рег.СуммаОборот) КАК Факт

	|ПОМЕСТИТЬ ВТ_Факт
	|ИЗ
	|	РегистрНакопления.ОборотыПоКатегориям.Обороты(НАЧАЛОПЕРИОДА(&Месяц, МЕСЯЦ), КОНЕЦПЕРИОДА(&Месяц, МЕСЯЦ), , Пользователь = &Пользователь) КАК Рег

	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР КОГДА Рег.Категория.ЭтоГруппа ТОГДА Рег.Категория ИНАЧЕ Рег.Категория.Родитель КОНЕЦ
	|;

	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ВТ_План.Категория, ВТ_Факт.Категория) КАК Категория,

	|	ЕСТЬNULL(ВТ_План.План, 0) КАК План,
	|	ЕСТЬNULL(ВТ_Факт.Факт, 0) КАК Факт
	|ИЗ

	|	ВТ_План КАК ВТ_План
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_Факт КАК ВТ_Факт
	|		ПО ВТ_План.Категория = ВТ_Факт.Категория";

	Запрос.УстановитьПараметр("Пользователь", ТекПользователь);
	Запрос.УстановитьПараметр("Месяц", НачалоМесяца(ТекущаяДата()));

	Выборка = Запрос.Выполнить().Выбрать();
	
	Текст = "*ДЕТАЛЬНЫЙ ОТЧЕТ ПО КАТЕГОРИЯМ*" + Символы.ПС + "---------------------------" + Символы.ПС + Символы.ПС;
	
	Пока Выборка.Следующий() Цикл
		ИмяКат = ?(ЗначениеЗаполнено(Выборка.Категория), Выборка.Категория.Наименование, "Без категории");
		Текст = Текст + СформироватьСтрокуПрогрессаКатегории(ИмяКат, Выборка.Факт, Выборка.План);
	КонецЦикла;
                                                 
	Возврат Текст;
КонецФункции
//Доп. функция к отчёту категорий
Функция СформироватьСтрокуПрогрессаКатегории(Заголовок, Факт, План)
	Процент = ?(План > 0, (-(Факт) / План) * 100, 0);
	Заполнено = Мин(Цел(Процент / 10), 10);
	Пусто = Макс(10 - Заполнено, 0);
	
	Индикатор = "[";
	Для Счетчик = 1 По Заполнено Цикл
		Индикатор = Индикатор + "■"; 
	КонецЦикла;
	Для Счетчик = 1 По Пусто Цикл
		Индикатор = Индикатор + "▫";
	КонецЦикла;
	Индикатор = Индикатор + "]";
	
	Результат = "*" + Заголовок + "* (" + Формат(Процент, "ЧЦ=3; ЧДЦ=0") + "%)" + Символы.ПС +
	            Индикатор + Символы.ПС +
	            "Ф: " + Формат(-(Факт), "ЧЦ=15; ЧДЦ=0") + " / П: " + Формат(План, "ЧЦ=15; ЧДЦ=0") + " р." + Символы.ПС + Символы.ПС;
	
	Возврат Результат;
КонецФункции
//Отчёт по 3-ём направлениям
Функция СформироватьОтчетИзРегистраИтоги(ЧатID) Экспорт
	ТекПользователь = ОпределитьПользователяПоID(ЧатID);	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ

	|	Итоги.ПланКатегории,
	|	Итоги.ФактКатегорииНаДату КАК ФактКатегории,
	|	Итоги.ПланАктивы,

	|	Итоги.ФактАктивыНаДату КАК ФактАктивы,
	|	Итоги.ПланВалюты,
	|	Итоги.ФактВалютыНаДату КАК ФактВалюты

	|ИЗ
	|	РегистрСведений.ИтогиПланаМесяца КАК Итоги
	|ГДЕ

	|	Итоги.Пользователь = &Пользователь
	|	И Итоги.Месяц = НАЧАЛОПЕРИОДА(&Дата, МЕСЯЦ)";
	
	Запрос.УстановитьПараметр("Пользователь", ТекПользователь);
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Текст = " *Ваш финансовый план на " + Формат(ТекущаяДата(), "ДФ='MMMM'") + "*" + Символы.ПС + Символы.ПС;
		
		// Обрабатываем три блока: Категории, Активы, Валюты
		Текст = Текст + СформироватьСтрокуПрогресса(" Категории", Выборка.ФактКатегории, Выборка.ПланКатегории);
		Текст = Текст + СформироватьСтрокуПрогресса(" Активы", Выборка.ФактАктивы, Выборка.ПланАктивы);
		Текст = Текст + СформироватьСтрокуПрогресса(" Валюты", Выборка.ФактВалюты, Выборка.ПланВалюты);
		
		Возврат Текст;
	Иначе
		Возврат "❌ Данные по бюджету на текущий месяц не найдены.";
	КонецЕсли;
	
КонецФункции
//Доп. функция к отчёту выше
Функция СформироватьСтрокуПрогресса(Заголовок, Факт, План)
	
	Процент = ?(План > 0, (Факт / План) * 100, 0);
	
	Заполнено = Мин(Цел(Процент / 10), 10);
	Пусто     = Макс(10 - Заполнено, 0);
	Индикатор = "["; 
	Для Счетчик = 1 По Заполнено Цикл
		Индикатор = Индикатор + "■"; 
	КонецЦикла;
	Для Счетчик = 1 По Пусто Цикл
		Индикатор = Индикатор + "▫"; 
	КонецЦикла;
	Индикатор = Индикатор + "]";
	
	Результат = "*" + Заголовок + "* (" + Формат(Процент, "ЧЦ=3; ЧДЦ=0") + "%)" + Символы.ПС +
	            Индикатор + Символы.ПС +
	            "Факт: " + Формат(Факт, "ЧЦ=15; ЧДЦ=0") + " / План: " + Формат(План, "ЧЦ=15; ЧДЦ=0") + " руб." + Символы.ПС + Символы.ПС;
	
	Возврат Результат;
	
КонецФункции
//Динамика
Функция СформироватьПрогнозТемпа(ЧатID) Экспорт
	
	ТекПользователь = ОпределитьПользователяПоID(ЧатID);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ

	|	Итоги.ПланКатегории КАК План,
	|	Итоги.ФактКатегорииНаДату КАК Факт
	|ИЗ

	|	РегистрСведений.ИтогиПланаМесяца КАК Итоги
	|ГДЕ
	|	Итоги.Пользователь = &Пользователь
	|	И Итоги.Месяц = НАЧАЛОПЕРИОДА(&Дата, МЕСЯЦ)";
	
	Запрос.УстановитьПараметр("Пользователь", ТекПользователь);
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		План = ?(Выборка.План = NULL, 0, Выборка.План);
		Факт = БюджетПланированиеСервер.ПолучитьФактКатегорииНаДату(ТекПользователь,ТекущаяДата(), ТекущаяДата());
		
		Если План = 0 Тогда Возврат "(!) План на месяц не задан, прогноз невозможен."; КонецЕсли;

		ТекДата = ТекущаяДата();
		ВсегоДнейВМесяце = День(КонецМесяца(ТекДата));
		ПрошлоДней = День(ТекДата);
		
		ДоляВремени = (ПрошлоДней / ВсегоДнейВМесяце) * 100;
		ДоляТрат    = (Факт / План) * 100;
		
		// 3. Прогноз
		СреднийРасходВДень = Факт / ПрошлоДней;
		ПрогнозНаКонецМесяца = СреднийРасходВДень * ВсегоДнейВМесяце;
		РазницаСПланом = ПрогнозНаКонецМесяца - План;
		
		// 4. Формируем текст
		Текст = "* АНАЛИЗ ТЕМПА ТРАТ *" + Символы.ПС + "---------------------------" + Символы.ПС;
		
		// Полоска времени
		Текст = Текст + "--- ВРЕМЯ: " + Формат(ДоляВремени, "ЧЦ=3; ЧДЦ=0") + "% месяца прошло" + Символы.ПС;
		Текст = Текст + РисоватьПолоску_Текст(ДоляВремени) + Символы.ПС;
		
		// Полоска денег
		Текст = Текст + "--- ТРАТЫ: " + Формат(ДоляТрат, "ЧЦ=3; ЧДЦ=0") + "% лимита съедено" + Символы.ПС;
		Текст = Текст + РисоватьПолоску_Текст(ДоляТрат) + Символы.ПС + Символы.ПС;
		
		// Вердикт
		Текст = Текст + "Прогноз к концу месяца: " + Формат(ПрогнозНаКонецМесяца, "ЧЦ=15; ЧДЦ=0") + " р." + Символы.ПС;
		
		Если РазницаСПланом > 0 Тогда
			Текст = Текст + "(!) ОЖИДАЕТСЯ ПЕРЕРАСХОД: *" + Формат(РазницаСПланом, "ЧЦ=15; ЧДЦ=0") + " р.*" + Символы.ПС;
			
			ДнейОсталось = (ВсегоДнейВМесяце - ПрошлоДней + 1);
			ДневнойЛимит = (План - Факт) / ДнейОсталось;
			
			Текст = Текст + "Совет: чтобы уложиться, трать не более *" + Формат(Макс(ДневнойЛимит, 0), "ЧЦ=15; ЧДЦ=0") + " р.* в день.";
		Иначе
			Текст = Текст + "(+) Идешь с экономией: *" + Формат(-РазницаСПланом, "ЧЦ=15; ЧДЦ=0") + " р.*";
		КонецЕсли;
		
		Возврат Текст;
	Иначе
		Возврат "(-) Нет данных для анализа.";
	КонецЕсли;
	
КонецФункции
//Доп. функция к динамике
Функция РисоватьПолоску_Текст(Процент)
	Заполнено = Мин(Цел(Процент / 10), 10);
	Рез = "[";
	Для Счетчик = 1 По Заполнено Цикл
		Рез = Рез + "■"; 
	КонецЦикла;
	Для Счетчик = 1 По (10-Заполнено) Цикл
		Рез = Рез + "▫"; 
	КонецЦикла;
	Возврат Рез + "]";
КонецФункции
//Календарь
Функция  СформироватьКалендарь() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(Задачи.ДатаИсполнения, ДЕНЬ) КАК День,
	|	Задачи.ДатаИсполнения КАК Время,
	|	Задачи.Наименование КАК Текст,
	|	Задачи.Статус КАК Выполнена
	|ИЗ
	|	Справочник.Задачи КАК Задачи
	|ГДЕ
	|	Задачи.ДатаИсполнения МЕЖДУ &Начало И &Конец
	|УПОРЯДОЧИТЬ ПО
	|	День,
	|	Время";
	
	Запрос.УстановитьПараметр("Начало", НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Конец",  КонецДня(ТекущаяДата() + 6 * 86400));
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Текст = " На ближайшую неделю планов нет. Свобода! ";
		Возврат Текст;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	
	Текст = " *ВАШ КАЛЕНДАРЬ НА 7 ДНЕЙ*" + Символы.ПС + "---------------------------" + Символы.ПС;
	
	ТекущийДень = Дата(1,1,1);
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.День <> ТекущийДень Тогда
			ТекущийДень = Выборка.День;
			Текст = Текст + Символы.ПС + " *" + Формат(ТекущийДень, "ДФ='dd MMMM (ddd)'") + "*" + Символы.ПС;
		КонецЕсли;
		
		Иконка = ?(Выборка.Выполнена, "✅", "⏳");
		Текст = Текст + Иконка + " " + Формат(Выборка.Время, "ДФ=HH:mm") + " — " + Выборка.Текст + Символы.ПС;
		
	КонецЦикла;
	
	Возврат Текст;
КонецФункции
