Процедура ЗаполнитьПоАктиву(ДокОбъект) Экспорт
	 Если ЗначениеЗаполнено(ДокОбъект.Актив) Тогда
	// Передаем и актив, и пользователя (если он уже выбран), чтобы найти точный остаток
	Данные = ПолучитьДанныеАктиваНаСервере(ДокОбъект.Актив, ДокОбъект.Пользователь);
	
	Если Данные <> Неопределено Тогда
		// 1. Сначала заполняем ссылочные поля
		ДокОбъект.Валюта       = Данные.Валюта;
		ДокОбъект.Пользователь = Данные.Пользователь;
		
		// 2. Затем заполняем числовое поле
		ДокОбъект.ТекущаяСтоимость = Данные.ЦенаИзРегистра;
	КонецЕсли;
	    КонецЕсли;
КонецПроцедуры

Функция ПолучитьДанныеАктиваНаСервере(СсылкаНаАктив, ТекущийПользователь)
    
    Если СсылкаНаАктив.Пустая() Тогда
        Возврат Неопределено;
    КонецЕсли;
    
    Результат = Новый Структура;
    Результат.Вставить("Валюта",       СсылкаНаАктив.Валюта);
    Результат.Вставить("Пользователь", СсылкаНаАктив.Пользователь);
    
    // Определяем пользователя для фильтра
    НужныйПользователь = ?(ЗначениеЗаполнено(ТекущийПользователь), ТекущийПользователь, СсылкаНаАктив.Пользователь);
    
    Запрос = Новый Запрос;
    // Оборачиваем СУММА в ЕСТЬNULL, чтобы всегда получать число
    Запрос.Текст = 
    "ВЫБРАТЬ


    |	ЕСТЬNULL(СУММА(Остатки.ТекущаяСтоимостьОстаток), 0) КАК Цена
    |ИЗ
    |	РегистрНакопления.ОстаткиАктивов.Остатки(&Период, Актив = &Актив И Пользователь = &Пользователь) КАК Остатки";
    
    // Используем ТекущаяДата или МоментВремени, чтобы видеть остатки на сейчас
    Запрос.УстановитьПараметр("Период",      ТекущаяДата());
    Запрос.УстановитьПараметр("Актив",       СсылкаНаАктив);
    Запрос.УстановитьПараметр("Пользователь", НужныйПользователь);
    
    Выборка = Запрос.Выполнить().Выбрать();
    
    Цена = 0;
    Если Выборка.Следующий() Тогда
        Цена = Выборка.Цена; // Теперь здесь гарантированно число (0 или больше)
    КонецЕсли;
    
    Результат.Вставить("ЦенаИзРегистра", Цена);
    
    Возврат Результат;
    
КонецФункции