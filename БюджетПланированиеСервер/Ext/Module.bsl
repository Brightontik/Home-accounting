Функция ПолучитьДоходМесяца(Пользователь, МесяцПлана) Экспорт

	НачПериода = НачалоМесяца(МесяцПлана);
	КонПериода = КонецМесяца(МесяцПлана);

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Доход.Сумма), 0) КАК СуммаДохода
	|ИЗ
	|	Документ.Доход КАК Доход
	|ГДЕ
	|	Доход.Проведен
	|	И Доход.Пользователь = &Пользователь
	|	И Доход.Дата МЕЖДУ &НачПериода И &КонПериода";

	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("НачПериода", НачПериода);
	Запрос.УстановитьПараметр("КонПериода", КонПериода);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.СуммаДохода;
	КонецЕсли;

	Возврат 0;

КонецФункции


Процедура ПересчитатьПланДокумента(ДокОбъект, Отказ) Экспорт

	Если НЕ ЗначениеЗаполнено(ДокОбъект.Пользователь) Тогда
		Сообщить("Не заполнен пользователь.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ДокОбъект.МесяцПлана) Тогда
		Сообщить("Не заполнен месяц плана.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	ДокОбъект.МесяцПлана = НачалоМесяца(ДокОбъект.МесяцПлана);
	ДокОбъект.ДоходМесяца = ПолучитьДоходМесяца(ДокОбъект.Пользователь, ДокОбъект.МесяцПлана);

	ДокОбъект.ОбязательныеТратыИтого = 0;
	Для Каждого СтрОб Из ДокОбъект.ОбязательныеТраты Цикл
		Если НЕ ЗначениеЗаполнено(СтрОб.Сумма) Тогда СтрОб.Сумма = 0; КонецЕсли;
		Если СтрОб.Сумма < 0 Тогда
			Сообщить("В обязательных тратах отрицательная сумма.");
			Отказ = Истина; Возврат;
		КонецЕсли;
		ДокОбъект.ОбязательныеТратыИтого = ДокОбъект.ОбязательныеТратыИтого + СтрОб.Сумма;
	КонецЦикла;

	ДокОбъект.ДоступноКПланированию = ДокОбъект.ДоходМесяца - ДокОбъект.ОбязательныеТратыИтого;
	Если ДокОбъект.ДоступноКПланированию < 0 Тогда
		Сообщить("Обязательные траты превышают доход месяца.");
		Отказ = Истина; Возврат;
	КонецЕсли;

	СуммаКатегорий = 0;
	Для Каждого СтрКат Из ДокОбъект.ПланПоКатегориям Цикл

		Если СтрКат.ТипРаспределенияБюджета = Перечисления.ТипРаспределенияБюджета.ФиксСумма Тогда
			Если НЕ ЗначениеЗаполнено(СтрКат.Сумма) Тогда СтрКат.Сумма = 0; КонецЕсли;
		ИначеЕсли СтрКат.ТипРаспределенияБюджета = Перечисления.ТипРаспределенияБюджета.Процент Тогда
			Если НЕ ЗначениеЗаполнено(СтрКат.Процент) Тогда СтрКат.Процент = 0; КонецЕсли;
			СтрКат.Сумма = Окр(ДокОбъект.ДоступноКПланированию * СтрКат.Процент / 100, 2);
		Иначе
			Сообщить("Не заполнен тип распределения в ПланПоКатегориям.");
			Отказ = Истина; Возврат;
		КонецЕсли;

		СуммаКатегорий = СуммаКатегорий + СтрКат.Сумма;
	КонецЦикла;

	ОстатокПослеКатегорий = ДокОбъект.ДоступноКПланированию - СуммаКатегорий;
	Если ОстатокПослеКатегорий < 0 Тогда
		Сообщить("Категории превышают доступный бюджет.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ПланАктивы = Окр(ОстатокПослеКатегорий * 0.7, 2);
	ПланВалюты = ОстатокПослеКатегорий - ПланАктивы;
	// Весь остаток распределен автоматически
	ДокОбъект.Нераспределено = 0;

	Если ДокОбъект.Нераспределено < 0 Тогда
		Сообщить("План превышает доступный бюджет.");
		Отказ = Истина; Возврат;
	КонецЕсли;

КонецПроцедуры

Функция ПолучитьФактКатегорииНаДату(Пользователь, МесяцПлана, ДатаСреза) Экспорт
	НачПериода = НачалоМесяца(МесяцПлана);
	КонПериода = Мин(КонецДня(ДатаСреза), КонецМесяца(МесяцПлана));
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Расход.Сумма), 0) КАК СуммаФакт
	|ИЗ
	|	Документ.Расход КАК Расход
	|ГДЕ
	|	Расход.Проведен
	|	И Расход.Пользователь = &Пользователь
	|	И Расход.Дата МЕЖДУ &НачПериода И &КонПериода";
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("НачПериода", НачПериода);
	Запрос.УстановитьПараметр("КонПериода", КонПериода);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.СуммаФакт;
	КонецЕсли;
	Возврат 0;
КонецФункции
